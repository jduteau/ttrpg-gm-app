ANTHROPIC_API_KEY=your_api_key_here
PORT=3001

# Simple password protection for the frontend
# Leave empty to disable authentication
APP_PASSWORD=your_secure_password_here

# Path to the content directory (rulesets, prompts, database).
# Defaults to ./content relative to the project root.
# CONTENT_DIR=/path/to/your/content

# Allowed CORS origins for separate client/server deploys.
# Comma-separated. Leave unset for combined (same-origin) deploys.
# CORS_ORIGIN=https://your-client.netlify.app

# MCP World Server Configuration
# URL to the world MCP server that provides campaign world information
# WORLD_MCP_SERVER_URL=ws://localhost:3333/ws
